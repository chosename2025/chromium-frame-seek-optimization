+bool FFmpegDemuxer::ShouldFastForward(base::TimeDelta media_time) const {
+  // Prefer video stream as reference; fall back to audio.
+  const FFmpegDemuxerStream* ref_stream =
+      GetFirstEnabledFFmpegStream(DemuxerStream::VIDEO);
+  if (!ref_stream)
+    ref_stream = GetFirstEnabledFFmpegStream(DemuxerStream::AUDIO);
+  if (!ref_stream) {
+    DVLOG(2) << __func__ << "(" << media_time << "): no stream → false";
+    return false;
+  }
+
+  const Ranges<base::TimeDelta> ranges = ref_stream->GetBufferedRanges();
+  if (ranges.empty()) {
+    DVLOG(2) << __func__ << "(" << media_time << "): no buffered ranges → false";
+    return false;
+  }
+
+  const base::TimeDelta buffer_start = ranges.start(0);
+  const base::TimeDelta buffer_end = ranges.end(ranges.size() - 1);
+
+  // Case 1: target is already inside the buffered range — data is in memory,
+  // no Demuxer::Seek() needed at all.
+  if (media_time >= buffer_start && media_time <= buffer_end) {
+    DVLOG(1) << __func__ << "(" << media_time << "): in buffer ["
+             << buffer_start << ", " << buffer_end << "] → true";
+    return true;
+  }
+
+  // Case 2: If the target is just ahead of the read head, the demuxer can reach media_time 
+  // by reading forward without av_seek_frame. If the gap exceeds kMaxLookahead, a regular seek is preferred.
+  const base::TimeDelta last_read = ref_stream->GetLastPacketTimestamp();
+  if (last_read == kNoTimestamp) {
+    DVLOG(2) << __func__ << "(" << media_time << "): no read head → false";
+    return false;
+  }
+
+  // Seeking backward requires av_seek_frame — never fast-forward in that case.
+  if (media_time < last_read) {
+    DVLOG(1) << __func__ << "(" << media_time << "): backward seek (read head="
+             << last_read << ") → false";
+    return false;
+  }
+
+  constexpr base::TimeDelta kMaxLookahead = base::Seconds(2);
+  const bool result = (media_time - last_read) <= kMaxLookahead;
+  DVLOG(1) << __func__ << "(" << media_time << "): read_head=" << last_read
+           << " lookahead=" << (media_time - last_read) << " → " << result;
+  return result;
+}
