+
+void RendererImpl::FastForwardTo(base::TimeDelta media_time,
+                                 PipelineStatusCallback seek_done_cb) {
+  DCHECK(task_runner_->RunsTasksInCurrentSequence());
+  DCHECK_EQ(state_, STATE_PLAYING);
+
+  // Don't call time_source_->SetMediaTime() here; FastForwardTo() handles the clock and calling SetMediaTime would DCHECK.
+
+  // Wait for all sub-renderers
+  if (!audio_renderer_ && !video_renderer_) {
+    std::move(seek_done_cb).Run(PIPELINE_OK);
+    return;
+  }
+
+  // Wrap seek_done_cb in a BarrierClosure so it fires once both audio and video
+  // have finished discarding their pre-|media_time| data.
+  int count = (audio_renderer_ ? 1 : 0) + (video_renderer_ ? 1 : 0);
+  base::RepeatingClosure barrier = base::BarrierClosure(
+      count,
+      base::BindOnce(std::move(seek_done_cb), PIPELINE_OK));
+
+  if (audio_renderer_)
+    audio_renderer_->FastForwardTo(media_time, barrier);
+  if (video_renderer_)
+    video_renderer_->FastForwardTo(media_time, barrier);
+}
