+template <DemuxerStream::Type StreamType>
+void DecoderStream<StreamType>::FastForwardTo(base::TimeDelta target_time) {
+  DCHECK(task_runner_->RunsTasksInCurrentSequence());
+
+  // Remove stale outputs before |target_time|.
+  while (!ready_outputs_.empty() &&
+         ready_outputs_.front()->timestamp() < target_time) {
+    ready_outputs_.pop_front();
+  }
+  while (!unprepared_outputs_.empty() &&
+         unprepared_outputs_.front()->timestamp() < target_time) {
+    unprepared_outputs_.pop_front();
+  }
+
+  // Frames the decoder has already started producing but hasn't emitted yet
+  // will be caught in OnDecodeOutputReady() via this threshold.
+  drop_before_timestamp_ = target_time;
+
+  // Align the GPU-preparation skip window so that frames just before
+  // |target_time| don't incur an unnecessary shared-image upload.
+  skip_prepare_until_timestamp_ = target_time;
+}
