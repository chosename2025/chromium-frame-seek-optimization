+void VideoRendererAlgorithm::DiscardFramesBefore(base::TimeDelta time) {
+  // Count how many leading frames fall before |time|, but always keep at least
+  // one so that Render() has something to return while the pipeline refills.
+  size_t to_discard = 0;
+  for (; to_discard + 1 < frame_queue_.size(); ++to_discard) {
+    if (frame_queue_[to_discard].frame->timestamp() >= time)
+      break;
+  }
+
+  if (!to_discard)
+    return;
+
+  // Advance the cadence counter in step with RemoveExpiredFrames() so that
+  // cadence-based ideal-render-count tracking remains consistent.
+  cadence_frame_counter_ += to_discard;
+  frame_queue_.erase(frame_queue_.begin(), frame_queue_.begin() + to_discard);
+
+  // Recompute the effective-frames count now that the queue has shrunk.
+  UpdateEffectiveFramesQueued();
+}
