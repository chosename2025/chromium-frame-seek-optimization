+void VideoRendererImpl::FastForwardTo(base::TimeDelta time,
+                                      base::OnceClosure callback) {
+  DVLOG(1) << __func__ << "(" << time.InMicroseconds() << ")";
+  DCHECK(task_runner_->RunsTasksInCurrentSequence());
+
+  bool needs_refill;
+  {
+    base::AutoLock auto_lock(lock_);
+    DCHECK_EQ(state_, kPlaying);
+
+    // Cancel any pending first-frame paint that was scheduled for the previous
+    // position; it will be re-triggered once the new position is rendered.
+    paint_first_frame_cb_.Cancel();
+
+    start_timestamp_ = time;
+    painted_first_frame_ = false;
+    last_render_time_ = last_frame_ready_time_ = base::TimeTicks();
+
+    received_end_of_stream_ = false;
+    rendered_end_of_stream_ = false;
+
+    // Discard only frames before |time|; keep already-decoded frames at |time| or later.
+    algorithm_->DiscardFramesBefore(start_timestamp_);
+
+    if (HaveEnoughData_Locked()) {
+      // Fast path: enough decoded frames are already buffered starting from
+      // |time|.  The running Render() loop will pick up the right frame on
+      // the next compositor tick without any decoder interaction.
+      needs_refill = false;
+    } else {
+      // Slow path: the buffer is thin after eviction (seek jumped far ahead,
+      // or the lookahead was not yet fully decoded).  Evict stale frames from
+      // the decoder stream's own queues, set the drop threshold for any
+      // in-flight frames, and request fresh decoded output.
+      needs_refill = true;
+      video_decoder_stream_->FastForwardTo(start_timestamp_);
+      TransitionToHaveNothing_Locked();
+      AttemptRead_Locked();
+    }
+  }
+
+  // StopSink() must be called without |lock_| to avoid deadlock with the
+  // sink callback thread.  Only stop when a buffer refill is actually needed;
+  // for the fast path the sink continues running and Render() is uninterrupted.
+  if (needs_refill && sink_started_)
+    StopSink();
+
+  std::move(callback).Run();
+}
