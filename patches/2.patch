+void AudioRendererImpl::FastForwardTo(base::TimeDelta time,
+                                      base::OnceClosure callback) {
+  DVLOG(1) << __func__ << "(" << time << ")";
+  DCHECK(task_runner_->RunsTasksInCurrentSequence());
+
+  // Evict stale decoded buffers from the decoder stream's output queues and
+  // set the drop threshold for any in-flight frames before |time|.
+  // This must be called before acquiring |lock_| because AttemptRead_Locked()
+  // releases |lock_| around decoder stream calls (see AutoUnlock there), so
+  // we follow the same pattern to avoid inconsistent lock ordering.
+  audio_decoder_stream_->FastForwardTo(time);
+
+  {
+    base::AutoLock auto_lock(lock_);
+    DCHECK_EQ(state_, kPlaying);
+
+    start_timestamp_ = time;
+    ended_timestamp_ = kInfiniteDuration;
+    first_packet_timestamp_ = kNoTimestamp;
+
+    received_end_of_stream_ = false;
+    rendered_end_of_stream_ = false;
+
+    // Reset the audio clock to the new origin so rendered timestamps are
+    // computed correctly from the seek position.
+    audio_clock_ =
+        std::make_unique<AudioClock>(time, audio_parameters_.sample_rate());
+
+    // Drop any decoded audio that the algorithm is still holding.
+    algorithm_->FlushBuffers();
+
+    if (buffering_state_ != BUFFERING_HAVE_NOTHING)
+      SetBufferingState_Locked(BUFFERING_HAVE_NOTHING);
+    AttemptRead_Locked();
+  }
+
+  // Audio has no visual blank-frame issue, so the pipeline can be unblocked
+  // immediately; the audio sink will simply output silence until new decoded
+  // buffers arrive from the decoder stream.
+  std::move(callback).Run();
+}
